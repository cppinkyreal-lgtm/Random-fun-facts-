<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Random Fun Facts</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            padding: 40px;
            max-width: 600px;
            width: 100%;
            text-align: center;
        }

        h1 {
            color: #333;
            margin-bottom: 30px;
            font-size: 2.5em;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .fact-box {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            border-radius: 15px;
            padding: 30px;
            margin: 30px 0;
            min-height: 120px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .fact-text {
            color: #333;
            font-size: 1.3em;
            line-height: 1.6;
            font-weight: 500;
        }

        .button-group {
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 30px;
        }

        button {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 12px 30px;
            font-size: 1em;
            border-radius: 25px;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            font-weight: 600;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        }

        button:active {
            transform: translateY(0);
        }

        .category-buttons {
            margin: 20px 0;
            display: flex;
            gap: 10px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .category-btn {
            background: #e0e7ff;
            color: #667eea;
            padding: 8px 16px;
            border-radius: 20px;
            border: 2px solid #667eea;
            cursor: pointer;
            font-size: 0.9em;
            transition: all 0.3s;
        }

        .category-btn.active {
            background: #667eea;
            color: white;
        }

        .category-btn:hover {
            background: #667eea;
            color: white;
        }

        .fact-counter {
            color: #999;
            font-size: 0.9em;
            margin-top: 15px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🎉 Fun Facts!</h1>
        
        <div class="category-buttons">
            <button class="category-btn active" onclick="filterCategory('all')">All</button>
            <button class="category-btn" onclick="filterCategory('science')">Science</button>
            <button class="category-btn" onclick="filterCategory('history')">History</button>
            <button class="category-btn" onclick="filterCategory('nature')">Nature</button>
            <button class="category-btn" onclick="filterCategory('technology')">Technology</button>
        </div>

        <div class="fact-box">
            <div class="fact-text" id="factDisplay">Click the button to get a fun fact!</div>
        </div>

        <div class="fact-counter">
            <span id="counter">Fact 0 of 0</span>
        </div>

        <div class="button-group">
            <button onclick="getRandomFact()">📖 New Fact</button>
            <button onclick="copyToClipboard()">📋 Copy</button>
        </div>
    </div>

    <script>
        const facts = {
            science: [
                "Honey never spoils. Archaeologists have found 3,000-year-old honey in Egyptian tombs that was still edible!",
                "A single bolt of lightning is 5 times hotter than the surface of the sun.",
                "Bananas are berries, but strawberries aren't!",
                "The human brain uses 20% of the body's energy while only making up 2% of its mass.",
                "An octopus has three hearts and blue blood.",
                "Light takes 8 minutes and 20 seconds to reach Earth from the sun.",
                "Diamonds rain on Jupiter and Saturn.",
                "A group of flamingos is called a 'flamboyance'.",
                "The Eiffel Tower grows about 6 inches taller in the summer due to thermal expansion."
            ],
            history: [
                "Cleopatra lived closer to the invention of the iPhone than to the construction of the Great Pyramid.",
                "Oxford University is older than the Aztec Empire.",
                "The shortest war in history lasted only 38 minutes (between Britain and Zanzibar in 1896).",
                "Julius Caesar was assassinated on the Ides of March (March 15) in 44 BC.",
                "The Great Wall of China is not visible from space with the naked eye.",
                "Vikings used to ski for transportation, not recreation.",
                "The last person executed by guillotine in France was in 1977.",
                "Teddy Roosevelt wrote a book in just two weeks while in the White House."
            ],
            nature: [
                "A giraffe's tongue can be up to 20 inches long.",
                "Sloths only defecate once a week.",
                "Polar bears have black skin under their white fur.",
                "A group of crows is called a 'murder'.",
                "Butterflies taste with their feet.",
                "Wombats produce cube-shaped poop.",
                "A cockroach can live for a week without its head.",
                "Penguins propose to their mates with a pebble.",
                "Otters hold hands while sleeping to avoid drifting apart."
            ],
            technology: [
                "The first webcam was created to monitor a coffee pot at Cambridge University.",
                "The '@' symbol in email is called 'asperand'.",
                "More data is created every 2 days now than was created throughout all of human history until 2003.",
                "The first computer mouse was made of wood.",
                "Python was named after Monty Python, not the snake.",
                "Amazon started as an online bookstore in Jeff Bezos's garage.",
                "The first image ever uploaded to the web was a picture of a CERN band.",
                "Over 6,000 new computer viruses are created every day."
            ]
        };

        let currentCategory = 'all';
        let currentFactIndex = 0;
        let filteredFacts = [];

        function getAllFacts() {
            return Object.values(facts).flat();
        }

        function getFilteredFacts() {
            if (currentCategory === 'all') {
                return getAllFacts();
            }
            return facts[currentCategory] || [];
        }

        function filterCategory(category) {
            currentCategory = category;
            currentFactIndex = 0;
            filteredFacts = getFilteredFacts();
            
            // Update active button
            document.querySelectorAll('.category-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');
            
            getRandomFact();
        }

        function getRandomFact() {
            if (filteredFacts.length === 0) {
                filteredFacts = getFilteredFacts();
            }
            
            currentFactIndex = Math.floor(Math.random() * filteredFacts.length);
            const fact = filteredFacts[currentFactIndex];
            document.getElementById('factDisplay').textContent = fact;
            document.getElementById('counter').textContent = `Fact ${currentFactIndex + 1} of ${filteredFacts.length}`;
        }

        function copyToClipboard() {
            const factText = document.getElementById('factDisplay').textContent;
            navigator.clipboard.writeText(factText).then(() => {
                const button = event.target;
                const originalText = button.textContent;
                button.textContent = '✓ Copied!';
                setTimeout(() => {
                    button.textContent = originalText;
                }, 2000);
            });
        }

        // Initialize
        filteredFacts = getAllFacts();
        getRandomFact();
    </script>
</body>
</html>
